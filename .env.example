# API Keys for various services
ENVIRONMENT=development
API_KEY=dev-local-only-change-me
ALLOWED_ORIGIN=http://127.0.0.1:5173
VITE_API_BASE_URL=http://127.0.0.1:8011
VITE_API_KEY=dev-local-only-change-me

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=False

# OpenAI keys
GPT_4O_API=your_openai_key_here
GPT_41_API=your_openai_key_here

# Search tools
TAVILY_API_KEY=your_tavily_key_here

# DeepSeek job analysis agent
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# BOSS scraper
BOSS_HEADLESS=false
BOSS_USER_DATA_DIR=browser-data/boss
BOSS_MANUAL_CHECK_SECONDS=60

# LinkedIn credentials for scraping (REQUIRED)
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Glassdoor credentials for scraping (OPTIONAL)
GLASSDOOR_USERNAME=your_glassdoor_email@example.com
GLASSDOOR_PASSWORD=your_glassdoor_password

# Logging level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
